{
    "tech_stack": [
        "Python",
        "FastAPI",
        "SQLAlchemy",
        "Pydantic"
    ],
    "features": [
        {
            "name": "Submit Essay",
            "description": "API to submit an essay with validation logic for WPM and paste count.",
            "files": [
                "main.py",
                "database.py"
            ],
            "api_doc": {
                "openapi": "3.0.0",
                "info": {
                    "title": "Clio API",
                    "version": "1.0.0"
                },
                "paths": {
                    "/submit": {
                        "post": {
                            "summary": "Submit Essay",
                            "operationId": "submit_essay",
                            "requestBody": {
                                "content": {
                                    "application/json": {
                                        "schema": {
                                            "$ref": "#/components/schemas/SubmissionRequest"
                                        }
                                    }
                                },
                                "required": true
                            },
                            "responses": {
                                "200": {
                                    "description": "Successful Response",
                                    "content": {
                                        "application/json": {
                                            "schema": {
                                                "type": "object",
                                                "properties": {
                                                    "message": {
                                                        "type": "string"
                                                    },
                                                    "score": {
                                                        "type": "integer"
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "components": {
                    "schemas": {
                        "SubmissionRequest": {
                            "title": "SubmissionRequest",
                            "required": [
                                "student_id",
                                "assignment_title",
                                "content",
                                "wpm",
                                "paste_count"
                            ],
                            "type": "object",
                            "properties": {
                                "student_id": {
                                    "title": "Student Id",
                                    "type": "string"
                                },
                                "assignment_title": {
                                    "title": "Assignment Title",
                                    "type": "string"
                                },
                                "content": {
                                    "title": "Content",
                                    "type": "string"
                                },
                                "wpm": {
                                    "title": "Wpm",
                                    "type": "integer"
                                },
                                "paste_count": {
                                    "title": "Paste Count",
                                    "type": "integer"
                                }
                            }
                        }
                    }
                }
            }
        },
        {
            "name": "Get Submissions",
            "description": "API to retrieve all submissions.",
            "files": [
                "main.py",
                "database.py"
            ],
            "api_doc": {
                "openapi": "3.0.0",
                "paths": {
                    "/submissions": {
                        "get": {
                            "summary": "Get Submissions",
                            "operationId": "get_submissions",
                            "responses": {
                                "200": {
                                    "description": "Successful Response",
                                    "content": {
                                        "application/json": {
                                            "schema": {
                                                "type": "array",
                                                "items": {
                                                    "$ref": "#/components/schemas/Submission"
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "components": {
                    "schemas": {
                        "Submission": {
                            "type": "object",
                            "properties": {
                                "student_id": {
                                    "type": "string"
                                },
                                "assignment_title": {
                                    "type": "string"
                                },
                                "content": {
                                    "type": "string"
                                },
                                "wpm": {
                                    "type": "integer"
                                },
                                "paste_count": {
                                    "type": "integer"
                                }
                            }
                        }
                    }
                }
            }
        }
    ]
}